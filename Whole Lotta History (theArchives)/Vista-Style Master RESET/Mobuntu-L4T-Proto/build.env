# =============================================================================
# Mobuntu-L4T build configuration
# =============================================================================
# Sourced by all scripts/0X-*.sh. Override via environment or edit in place.
#
# Target: Nintendo Switch (Tegra X1, T210/T210B01) via switchroot/L4T stack
# Maintainers upstream: CTCaer (kernel/bootloader), theofficialgman (distro)
# =============================================================================

# ---- Distro -----------------------------------------------------------------
UBUNTU_SUITE="${UBUNTU_SUITE:-noble}"          # noble = 24.04 LTS, jammy = 22.04
UBUNTU_VERSION="${UBUNTU_VERSION:-24.04}"
ARCH="${ARCH:-arm64}"
FLAVOR="${FLAVOR:-ubuntu-unity-desktop}"        # kubuntu-desktop | ubuntu-unity-desktop
                                                # gnome currently broken upstream (mutter bug)

# ---- L4T release tracking ---------------------------------------------------
L4T_RELEASE="${L4T_RELEASE:-5.1.2}"             # tracks switchroot release tag
HEKATE_MIN_VERSION="${HEKATE_MIN_VERSION:-6.0.6}"

# ---- Build paths ------------------------------------------------------------
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
BUILD_DIR="${BUILD_DIR:-${PROJECT_ROOT}/build}"
ROOTFS_DIR="${ROOTFS_DIR:-${BUILD_DIR}/rootfs}"
DEBS_DIR="${DEBS_DIR:-${BUILD_DIR}/debs}"
IMAGE_DIR="${IMAGE_DIR:-${BUILD_DIR}/image}"
OUTPUT_DIR="${OUTPUT_DIR:-${PROJECT_ROOT}/output}"

# ---- Image geometry ---------------------------------------------------------
IMAGE_SIZE_MIB="${IMAGE_SIZE_MIB:-8192}"        # raw ext4 image size
SPLIT_SIZE_MIB="${SPLIT_SIZE_MIB:-4092}"        # hekate "Flash Linux" chunk size

# ---- Upstream sources -------------------------------------------------------
L4T_DEBS_REPO="${L4T_DEBS_REPO:-https://github.com/theofficialgman/l4t-debs.git}"
L4T_DEBS_BRANCH="${L4T_DEBS_BRANCH:-master}"

# ---- Mobuntu branding -------------------------------------------------------
DISTRO_NAME="${DISTRO_NAME:-mobuntu}"           # used for switchroot/<name>/ path
DISTRO_LABEL="${DISTRO_LABEL:-SWR-MOB}"         # FAT label for hekate id=
HEKATE_INI_NAME="${HEKATE_INI_NAME:-L4T-Mobuntu.ini}"
HEKATE_BOOT_PREFIX="/switchroot/${DISTRO_NAME}/"
HOSTNAME_DEFAULT="${HOSTNAME_DEFAULT:-mobuntu-switch}"

# ---- QEMU / debootstrap -----------------------------------------------------
# Auto-detected by script 01 based on host Ubuntu version.
# 24.04 host -> qemu-user-static
# 26.04 host -> qemu-user-binfmt-hwe (known segfault on some chroots)
QEMU_BIN="${QEMU_BIN:-/usr/bin/qemu-aarch64-static}"
UBUNTU_SNAPSHOT="${UBUNTU_SNAPSHOT:-}"          # optional snapshot pin (YYYYMMDDTHHMMSSZ)

# ---- Output naming ----------------------------------------------------------
RELEASE_TAG="${RELEASE_TAG:-dev}"               # color tag, RC number, etc.
OUTPUT_7Z="${OUTPUT_7Z:-mobuntu-l4t-${UBUNTU_SUITE}-${RELEASE_TAG}.7z}"
