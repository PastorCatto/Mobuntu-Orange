# =============================================================================
# Mobuntu-PS4 build configuration
# =============================================================================
# Target: Sony PlayStation 4 (x86-64, AMD Jaguar + GCN Liverpool GPU)
# Tested firmware: 12.52 (GoldHen jailbreak)
# Model focus: CUH-12xx (Belize/Aeolia southbridge)
#
# NOTE: x86-64 target — no QEMU, no cross-compilation, no arm64.
# Any x86-64 Ubuntu 24.04 host (including WSL2) works.
# =============================================================================

# ---- Distro -----------------------------------------------------------------
UBUNTU_SUITE="${UBUNTU_SUITE:-noble}"
UBUNTU_VERSION="${UBUNTU_VERSION:-24.04}"
ARCH="${ARCH:-amd64}"
UBUNTU_SNAPSHOT="${UBUNTU_SNAPSHOT:-}"

# ---- Kernel -----------------------------------------------------------------
# feeRnt/ps4-linux-12xx — CUH-12xx focused, WiFi/BT fixes, Marvell 8897.
# Set KERNEL_MODE=prebuilt to fetch the release bzImage (default, fast).
# Set KERNEL_MODE=source to build from the repo (slow, needs toolchain).
KERNEL_MODE="${KERNEL_MODE:-prebuilt}"

# GitHub API / release URL for prebuilt fetch.
KERNEL_REPO="${KERNEL_REPO:-feeRnt/ps4-linux-12xx}"
# Tag of the release to fetch. "latest" resolves via GitHub API.
KERNEL_TAG="${KERNEL_TAG:-latest}"

# If KERNEL_MODE=source, clone this repo + branch.
KERNEL_SOURCE_REPO="${KERNEL_SOURCE_REPO:-https://github.com/feeRnt/ps4-linux-12xx.git}"
KERNEL_SOURCE_BRANCH="${KERNEL_SOURCE_BRANCH:-main}"

# ---- Known-good kernel cmdline (from feeRnt 6.15.4 release notes) ----------
# Override if your PS4 model needs something different.
PS4_CMDLINE="${PS4_CMDLINE:-panic=0 clocksource=tsc consoleblank=0 net.ifnames=0 radeon.dpm=0 amdgpu.dpm=0 drm.debug=0 console=uart8250,mmio32,0xd0340000 console=ttyS0,115200n8 console=tty0 drm.edid_firmware=edid/1920x1080.bin}"

# ---- Build paths ------------------------------------------------------------
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
BUILD_DIR="${BUILD_DIR:-${PROJECT_ROOT}/build}"
ROOTFS_DIR="${ROOTFS_DIR:-${BUILD_DIR}/rootfs}"
KERNEL_DIR="${KERNEL_DIR:-${BUILD_DIR}/kernel}"
IMAGE_DIR="${IMAGE_DIR:-${BUILD_DIR}/image}"
OUTPUT_DIR="${OUTPUT_DIR:-${PROJECT_ROOT}/output}"

# ---- USB image geometry -----------------------------------------------------
# Output is a raw disk image: partition 1 = FAT32 boot, partition 2 = ext4 rootfs.
# dd this directly to a USB drive.
BOOT_PART_SIZE_MIB="${BOOT_PART_SIZE_MIB:-256}"    # FAT32: bzImage + initramfs
ROOTFS_SIZE_MIB="${ROOTFS_SIZE_MIB:-8192}"          # ext4: rootfs
# Total image = BOOT_PART_SIZE_MIB + ROOTFS_SIZE_MIB + 2 MiB (partition table)

# ---- Mobuntu branding -------------------------------------------------------
DISTRO_NAME="${DISTRO_NAME:-mobuntu-ps4}"
HOSTNAME_DEFAULT="${HOSTNAME_DEFAULT:-mobuntu-ps4}"

# ---- Output -----------------------------------------------------------------
RELEASE_TAG="${RELEASE_TAG:-dev}"
OUTPUT_IMG="${OUTPUT_IMG:-mobuntu-ps4-${UBUNTU_SUITE}-${RELEASE_TAG}.img}"
