[Unit]
Description=Mobuntu PS4 X Session (Doctor Octavius)
After=network.target sound.target bluetooth.target
Wants=sound.target

[Service]
Type=simple
User=mobuntu
PAMName=login
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=DISPLAY=:0
ExecStartPre=/bin/mkdir -p /var/mobuntu
ExecStartPre=/bin/sh -c 'echo console > /var/mobuntu/session-mode'
ExecStart=/usr/bin/startx /etc/X11/xinit/xinitrc -- :0 vt1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
